// Report application models

enum DbType {
  MYSQL
}

enum ChartType {
  BAR
  LINE
  PIE
  DOUGHNUT
  SCATTER
  AREA
  TABLE
}

enum FilterType {
  MULTI_SELECT
  SINGLE_SELECT
  DATE_RANGE
  TEXT
  NUMBER
}

model DbConnection {
  id                String  @id @default(uuid())
  name              String
  dbType            DbType  @map("db_type")
  host              String
  port              Int
  databaseName      String  @map("database_name")
  username          String
  encryptedPassword String  @map("encrypted_password") @db.LongText

  charts Chart[]
  dashboardFilters DashboardFilter[]

  createdBy String?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  createdIp String?   @map("created_ip")
  updatedBy String?   @map("updated_by")
  updatedAt DateTime? @updatedAt @map("updated_at")
  updatedIp String?   @map("updated_ip")

  @@map("rpt_db_connections")
}

model AiProvider {
  id              String  @id @default(uuid())
  name            String
  model           String
  encryptedApiKey String  @map("encrypted_api_key") @db.LongText
  isEnabled       Boolean @default(false) @map("is_enabled")

  createdBy String?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  createdIp String?   @map("created_ip")
  updatedBy String?   @map("updated_by")
  updatedAt DateTime? @updatedAt @map("updated_at")
  updatedIp String?   @map("updated_ip")

  @@map("rpt_ai_providers")
}

model Chart {
  id           String    @id @default(uuid())
  name         String
  connectionId String    @map("connection_id")
  sqlQuery     String    @map("sql_query") @db.LongText
  chartType    ChartType @map("chart_type")
  chartConfig  Json      @map("chart_config")

  connection     DbConnection     @relation(fields: [connectionId], references: [id])
  dashboardCharts DashboardChart[]

  createdBy String?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  createdIp String?   @map("created_ip")
  updatedBy String?   @map("updated_by")
  updatedAt DateTime? @updatedAt @map("updated_at")
  updatedIp String?   @map("updated_ip")

  @@map("rpt_charts")
}

model Dashboard {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text

  dashboardCharts  DashboardChart[]
  dashboardFilters DashboardFilter[]

  createdBy String?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  createdIp String?   @map("created_ip")
  updatedBy String?   @map("updated_by")
  updatedAt DateTime? @updatedAt @map("updated_at")
  updatedIp String?   @map("updated_ip")

  @@map("rpt_dashboards")
}

model DashboardChart {
  id          String @id @default(uuid())
  dashboardId String @map("dashboard_id")
  chartId     String @map("chart_id")
  positionX   Int    @default(0) @map("position_x")
  positionY   Int    @default(0) @map("position_y")
  width       Int    @default(6) @map("width")
  height      Int    @default(4) @map("height")
  order       Int    @default(0)

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  chart     Chart     @relation(fields: [chartId], references: [id], onDelete: Cascade)

  createdBy String?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  createdIp String?   @map("created_ip")
  updatedBy String?   @map("updated_by")
  updatedAt DateTime? @updatedAt @map("updated_at")
  updatedIp String?   @map("updated_ip")

  @@unique([dashboardId, chartId])
  @@map("rpt_dashboard_charts")
}

model DashboardFilter {
  id           String     @id @default(uuid())
  dashboardId  String     @map("dashboard_id")
  name         String
  filterType   FilterType @map("filter_type")
  connectionId String     @map("connection_id")
  targetColumn String     @map("target_column")
  sourceQuery  String?    @map("source_query") @db.LongText
  defaultValue String?    @map("default_value") @db.Text
  order        Int        @default(0)

  dashboard  Dashboard    @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  connection DbConnection @relation(fields: [connectionId], references: [id])

  createdBy String?   @map("created_by")
  createdAt DateTime  @default(now()) @map("created_at")
  createdIp String?   @map("created_ip")
  updatedBy String?   @map("updated_by")
  updatedAt DateTime? @updatedAt @map("updated_at")
  updatedIp String?   @map("updated_ip")

  @@map("rpt_dashboard_filters")
}
