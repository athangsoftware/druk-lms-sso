// RBAC - Resource-Based Access Control models

model Resource {
  id   String @id @default(uuid())
  name String @unique

  permissions Permission[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("rbac_resources")
}

model Action {
  id   String @id @default(uuid())
  name String @unique

  permissions Permission[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("rbac_actions")
}

model Permission {
  id         String @id @default(uuid())
  resourceId String @map("resource_id")
  actionId   String @map("action_id")
  groupId    String? @map("group_id")

  resource Resource         @relation(fields: [resourceId], references: [id])
  action   Action           @relation(fields: [actionId], references: [id])
  group    PermissionGroup? @relation(fields: [groupId], references: [id])

  isActive Boolean @default(true) @map("is_active")

  roles RolePermission[]

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([resourceId, actionId])
  @@map("rbac_permissions")
}

model PermissionGroup {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  permissions Permission[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("rbac_permission_groups")
}

model Role {
  id   String @id @default(uuid())
  name String @unique

  parentRoleId String? @map("parent_role_id")
  parentRole   Role?   @relation("RoleHierarchy", fields: [parentRoleId], references: [id])
  children     Role[]  @relation("RoleHierarchy")

  permissions RolePermission[]
  users       UserRole[]

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("rbac_roles")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("rbac_role_permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  assignedAt DateTime @default(now()) @map("assigned_at")

  @@id([userId, roleId])
  @@map("rbac_user_roles")
}
