{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/sso/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "webpackConfigPath": "webpack.config.js",
    "tsConfigPath": "apps/sso/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/sso",
  "projects": {
    "sso": {
      "type": "application",
      "root": "apps/sso",
      "entryFile": "main",
      "sourceRoot": "apps/sso/src",
      "compilerOptions": {
        "tsConfigPath": "apps/sso/tsconfig.app.json"
      }
    },
    "report": {
      "type": "application",
      "root": "apps/report",
      "entryFile": "main",
      "sourceRoot": "apps/report/src",
      "compilerOptions": {
        "tsConfigPath": "apps/report/tsconfig.app.json"
      }
    },
    "prisma-sso": {
      "type": "library",
      "root": "apps/sso/prisma",
      "entryFile": "index",
      "sourceRoot": "apps/sso/prisma/src",
      "compilerOptions": {
        "tsConfigPath": "apps/sso/prisma/tsconfig.lib.json"
      }
    },
    "prisma-report": {
      "type": "library",
      "root": "apps/report/prisma",
      "entryFile": "index",
      "sourceRoot": "apps/report/prisma/src",
      "compilerOptions": {
        "tsConfigPath": "apps/report/prisma/tsconfig.lib.json"
      }
    },
    "shared": {
      "type": "library",
      "root": "libs/shared",
      "entryFile": "index",
      "sourceRoot": "libs/shared/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared/tsconfig.lib.json"
      }
    }
  }
}
